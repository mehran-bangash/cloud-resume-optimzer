{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "backend-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-03",
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI"
  }
}